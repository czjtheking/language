<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.steincker.dao.CustomerConfigLanguageMapper">
    <resultMap id="BaseResultMap" type="com.steincker.entity.CustomerConfigLanguage">
        <id column="id" jdbcType="BIGINT" property="id" />
        <result column="app" jdbcType="VARCHAR" property="app" />
        <result column="type" jdbcType="VARCHAR" property="type" />
        <result column="code" jdbcType="VARCHAR" property="code" />
        <result column="lang" jdbcType="VARCHAR" property="lang" />
        <result column="text" jdbcType="VARCHAR" property="text" />
        <result column="description" jdbcType="VARCHAR" property="description" />
        <result column="deleted" jdbcType="BIGINT" property="deleted" />
        <result column="create_by" jdbcType="BIGINT" property="createBy" />
        <result column="create_time" jdbcType="TIMESTAMP" property="createTime" />
        <result column="update_by" jdbcType="BIGINT" property="updateBy" />
        <result column="update_time" jdbcType="TIMESTAMP" property="updateTime" />
    </resultMap>

    <!-- 表、字段、查询 sql -->
    <sql id="table">`customer_config_language`</sql>
    <sql id="columns">
        `id`, `app`, `type`, `code`,`lang`, `text`,
        `description`, `deleted`, `create_by`, `create_time`, `update_by`, `update_time`
    </sql>
    <sql id="selectEntity">
        SELECT
        <include refid="columns"/>
        FROM
        <include refid="table"/>
    </sql>
    <sql id="Example_Where_Clause">
        <where>
            <foreach collection="oredCriteria" item="criteria" separator="or">
                <if test="criteria.valid">
                    <trim prefix="(" prefixOverrides="and" suffix=")">
                        <foreach collection="criteria.criteria" item="criterion">
                            <choose>
                                <when test="criterion.noValue">
                                    and ${criterion.condition}
                                </when>
                                <when test="criterion.singleValue">
                                    and ${criterion.condition} #{criterion.value}
                                </when>
                                <when test="criterion.betweenValue">
                                    and ${criterion.condition} #{criterion.value} and #{criterion.secondValue}
                                </when>
                                <when test="criterion.listValue">
                                    and ${criterion.condition}
                                    <foreach close=")" collection="criterion.value" item="listItem" open="(" separator=",">
                                        #{listItem}
                                    </foreach>
                                </when>
                            </choose>
                        </foreach>
                    </trim>
                </if>
            </foreach>
        </where>
    </sql>
    <update id="setGroupConcatMaxLen">
        SET SESSION group_concat_max_len = 16777216
    </update>
    <select id="findAllGroupBy" resultType="com.steincker.entity.CustomerConfigLanguage">
        SELECT
        type,
        code,
        GROUP_CONCAT(DISTINCT lang ORDER BY lang SEPARATOR ',') AS lang,
        GROUP_CONCAT(text ORDER BY lang SEPARATOR '|') AS text
        FROM
        customer_config_language
        WHERE
        deleted = 0
        GROUP BY
        type, code
        ORDER BY
        type, code asc;
    </select>
    <select id="findAll" resultType="com.steincker.dao.CustomerConfigLanguageMapper">
        <include refid="selectEntity"/>
        WHERE `deleted` = 0
        order by `type` asc, code asc
    </select>
</mapper>